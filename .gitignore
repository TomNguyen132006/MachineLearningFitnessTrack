# Python cache files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.env
.venv
venv/
env/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/

# Data files
# Keep raw and processed datasets out of GitHub because they can be large or contain participant-specific data.
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Generated reports and figures
reports/figures/*
!reports/figures/.gitkeep

# Model artifacts
models/
*.pkl
*.joblib
